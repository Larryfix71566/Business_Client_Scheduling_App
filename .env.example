# Copy to .env and fill in. The committed .env is gitignored.

# Embedded Postgres (managed by `npm run db:start`; see CLAUDE.md).
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/appdb"

# Auth.js session secret. Generate one with: openssl rand -hex 32
AUTH_SECRET="change-me-generate-with-openssl-rand-hex-32"
NEXTAUTH_URL="http://localhost:3000"

# Notifications: "console" logs SMS/email to stdout in dev.
# Swap to a real driver + provider creds (Twilio/Resend) for production.
NOTIFY_DRIVER="console"

# Square payment reconciliation (read-only): "fake" uses in-memory fixtures.
# Set to "live" and supply per-business Square tokens for real payment history.
SQUARE_DRIVER="fake"
